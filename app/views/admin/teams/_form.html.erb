<%= form_with model: [:admin, @team], local: true, class: "form--vertical",
  data: { controller: "team-members", remove_text: t("admin.teams.attributes.remove_member") } do |form| %>
  <% if @team.errors.any? %>
    <div class="alert alert--error">
      <div class="alert__icon-container">
        <svg class="alert__icon alert__icon--error" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="alert__content">
        <p class="alert__text alert__text--error">
          <%= t("activerecord.errors.template.header", count: @team.errors.count) %>
        </p>
        <ul class="mt-2 text-sm text-red-700 dark:text-red-400 list-disc list-inside">
          <% @team.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :name, t("admin.teams.attributes.name"), class: "form-label" %>
      <div class="form-field">
        <%= form.text_field :name, class: "form-input", required: true %>
      </div>
    </div>

    <div>
      <%= form.label :unit_id, t("admin.teams.attributes.unit"), class: "form-label" %>
      <div class="form-field">
        <% if current_user.unit_lead? %>
          <%= form.collection_select :unit_id, [current_user.unit], :id, :name, {}, class: "form-input", required: true, disabled: true %>
        <% else %>
          <%= form.collection_select :unit_id, Unit.order(:name), :id, :name, {}, class: "form-input", required: true %>
        <% end %>
      </div>
    </div>
  </div>

  <div>
    <%= form.label :description, t("admin.teams.attributes.description"), class: "form-label" %>
    <div class="form-field">
      <%= form.text_area :description, class: "form-input", rows: 3 %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :team_lead_id, t("admin.teams.attributes.team_lead"), class: "form-label" %>
      <div class="form-field">
        <%= form.collection_select :team_lead_id, @team.users.order(:first_name, :last_name), :id, :display_name_or_full_name, {include_blank: true}, class: "form-input", data: { team_members_target: "teamLeadSelect" } %>
      </div>
    </div>

    <div>
      <%= form.label :active, t("admin.teams.attributes.active"), class: "form-label" %>
      <div class="form-field">
        <%= form.select :active, options_for_select([
          [t("admin.teams.active"), true],
          [t("admin.teams.inactive"), false]
        ], @team.active), {}, class: "form-input" %>
      </div>
    </div>
  </div>

  <div>
    <label class="form-label"><%= t("admin.teams.attributes.members") %></label>
    <div class="form-field space-y-3">
      <div data-team-members-target="memberList" class="member-list">
        <% @team.users.order(:first_name, :last_name).each do |member| %>
          <div data-member-id="<%= member.id %>" data-member-name="<%= member.display_name_or_full_name %>" data-member-row="<%= member.id %>" class="member-list__row">
            <span class="member-list__name"><%= member.display_name_or_full_name %></span>
            <button type="button" class="btn btn--small btn--secondary member-list__remove" data-action="click->team-members#remove">
              <%= t("admin.teams.attributes.remove_member") %>
            </button>
          </div>
        <% end %>
      </div>

      <div class="flex gap-3">
        <% if @available_members.present? %>
          <select data-team-members-target="addSelect" class="form-input flex-1">
            <option value="">-- <%= t("admin.teams.attributes.add_member") %> --</option>
            <% @available_members.each do |user| %>
              <option value="<%= user.id %>"><%= user.display_name_or_full_name %></option>
            <% end %>
          </select>
          <button type="button" class="btn btn--small btn--secondary" data-action="click->team-members#add">
            <%= t("admin.teams.attributes.add_member") %>
          </button>
        <% else %>
          <p class="text-sm text-gray-500 dark:text-gray-400"><%= t("admin.teams.attributes.no_available_members") %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="form-submit flex gap-4">
    <%= form.submit class: "btn btn--primary" %>
    <%= link_to t("admin.teams.cancel"), admin_teams_path, class: "btn btn--secondary" %>
  </div>
<% end %>
