<div class="page-header">
  <div class="page-header__container">
    <div class="page-header__content">
      <h1 class="page-title"><%= t("admin.quarters.title") %></h1>
      <% if policy([:admin, Quarter]).new? %>
        <%= link_to t("admin.quarters.new"), new_admin_quarter_path, class: "btn btn--primary" %>
      <% end %>
    </div>
  </div>
</div>

<main class="page-main">
  <div class="card">
    <div class="card__body">
      <%= form_tag admin_quarters_path, method: :get, class: "mb-6" do %>
        <div class="field field--inline">
          <%= label_tag :status, t("admin.quarters.filter_by_status", default: "Фильтр по статусу"), class: "label" %>
          <%= select_tag :status, 
              options_for_select([[t("admin.quarters.all_statuses", default: "Все"), ""]] + Quarter.statuses.keys.map { |s| [t("activerecord.attributes.quarter.statuses.#{s}", default: s.humanize), s] }, params[:status]),
              class: "input",
              onchange: "this.form.submit()" %>
        </div>
      <% end %>

      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th class="table__header-cell"><%= t("activerecord.attributes.quarter.name") %></th>
              <th class="table__header-cell"><%= t("admin.quarters.show.status") %></th>
              <th class="table__header-cell"><%= t("admin.quarters.show.dates") %></th>
              <th class="table__header-cell"><%= t("admin.quarters.actions.title", default: "Действия") %></th>
            </tr>
          </thead>
          <tbody>
            <% @quarters.each do |quarter| %>
              <tr>
                <td class="table__cell">
                  <%= link_to quarter.name, admin_quarter_path(quarter), class: "link" %>
                </td>
                <td class="table__cell">
                  <% badge_class = case quarter.status
                    when 'active' then 'badge--success'
                    when 'closed' then 'badge--warning'
                    when 'archived' then 'badge--danger'
                    else 'badge--secondary'
                  end %>
                  <span class="badge <%= badge_class %>">
                    <%= t("activerecord.attributes.quarter.statuses.#{quarter.status}", default: quarter.status) %>
                  </span>
                </td>
                <td class="table__cell"><%= l(quarter.start_date, format: :short) %> - <%= l(quarter.end_date, format: :short) %></td>
                <td class="table__cell">
                  <div class="flex items-center gap-2">
                    <% if quarter.draft? && policy([:admin, quarter]).activate? %>
                      <%= button_to t("admin.quarters.actions.activate"), activate_admin_quarter_path(quarter), method: :post, class: "btn btn--small btn--primary" %>
                    <% end %>
                    
                    <% if quarter.active? && policy([:admin, quarter]).close? %>
                      <%= button_to t("admin.quarters.actions.close"), close_admin_quarter_path(quarter), method: :post, class: "btn btn--small btn--warning" %>
                    <% end %>
                    
                    <% if quarter.closed? && policy([:admin, quarter]).archive? %>
                      <%= button_to t("admin.quarters.actions.archive"), archive_admin_quarter_path(quarter), method: :post, class: "btn btn--small btn--danger" %>
                    <% end %>
                    
                    <% if quarter.draft? && policy([:admin, quarter]).destroy? %>
                      <%= button_to t("admin.quarters.actions.delete"), admin_quarter_path(quarter), method: :delete, data: {confirm: t("admin.quarters.confirm_delete", default: "Удалить квартал?")}, class: "btn btn--small btn--danger" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <%= paginate @quarters %>
    </div>
  </div>
</main>
