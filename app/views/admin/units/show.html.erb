<div class="page-header">
  <div class="page-header__container">
    <div class="page-header__content">
      <h1 class="page-title"><%= t("admin.units.show") %></h1>
      <div class="flex gap-2">
        <%= link_to t("admin.units.edit"), edit_admin_unit_path(@unit), class: "btn btn--primary" %>
        <%= button_to t("admin.units.destroy"), admin_unit_path(@unit), method: :delete, class: "btn btn--danger", data: {turbo_confirm: t("admin.units.confirm_destroy")} %>
      </div>
    </div>
  </div>
</div>

<main class="page-main">
  <div class="card">
    <div class="card__body">
      <dl class="grid grid-cols-2 gap-4">
        <div class="field">
          <dt class="label"><%= t("admin.units.attributes.name") %></dt>
          <dd class="value"><%= @unit.name %></dd>
        </div>

        <div class="field">
          <dt class="label"><%= t("admin.units.attributes.unit_lead") %></dt>
          <dd class="value">
            <% if @unit.unit_lead.present? %>
              <span class="badge badge--secondary"><%= @unit.unit_lead.display_name_or_full_name %></span>
            <% else %>
              -
            <% end %>
          </dd>
        </div>

        <div class="field">
          <dt class="label"><%= t("admin.units.attributes.active") %></dt>
          <dd class="value">
            <% if @unit.active? %>
              <span class="badge badge--success"><%= t("admin.units.active") %></span>
            <% else %>
              <span class="badge badge--danger"><%= t("admin.units.inactive") %></span>
            <% end %>
          </dd>
        </div>

        <div class="field col-span-2">
          <dt class="label"><%= t("admin.units.attributes.description") %></dt>
          <dd class="value"><%= @unit.description.presence || "-" %></dd>
        </div>

        <div class="field">
          <dt class="label"><%= t("admin.units.attributes.created_at") %></dt>
          <dd class="value"><%= I18n.l(@unit.created_at, format: :short) %></dd>
        </div>

        <div class="field">
          <dt class="label"><%= t("admin.units.attributes.updated_at") %></dt>
          <dd class="value"><%= I18n.l(@unit.updated_at, format: :short) %></dd>
        </div>
      </dl>
    </div>
  </div>
</main>
