<div class="flex flex-col min-h-screen">
   <main class="flex-1 flex flex-col">
     <div class="page-header">
       <div class="page-header__container">
         <div class="page-header__content">
           <h1 class="page-title"><%= t('units.show.title') %></h1>
           <% if @current_quarter %>
             <span class="badge badge--primary">
               <%= @current_quarter.name %>
             </span>
           <% end %>
         </div>
       </div>
     </div>

      <main class="page-main">
        <% if @current_quarter %>
          <div class="card mb-8">
             <div class="card__body">
               <div class="flex items-center justify-between gap-8">
                 <div class="flex items-center gap-8">
                   <div>
                     <dt class="label"><%= t('units.show.unit') %></dt>
                     <dd class="value--large"><%= @unit&.name || t('units.show.not_assigned') %></dd>
                   </div>
                   <div>
                     <dt class="label"><%= t('units.show.unit_lead') %></dt>
                     <dd class="value--medium"><%= @unit&.unit_lead&.display_name_or_full_name || '-' %></dd>
                   </div>
                 </div>

                  <% if @teams&.any? %>
                    <div class="flex-shrink-0">
                      <div class="inline-flex flex-wrap gap-2">
                        <% @teams.each do |team| %>
                          <%= link_to team_path(team), class: "team-link" do %>
                            <span class="truncate max-w-[150px]"><%= team.name %></span>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
               </div>
             </div>
           </div>

           <div class="flex flex-wrap gap-6 mb-8">
             <%= render CoverageIndexComponent.new(coverage_index: @coverage_index) %>
             <%= render MaturityIndexComponent.new(maturity_index: @maturity_index) %>
              <%= render RedZonesCardComponent.new(red_zones_count: @red_zones_count) %>
             <%= render KeyPersonRisksComponent.new(key_person_risks_count: @key_person_risks_count) %>
           </div>

           <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
              <%= render RedZonesDetailsComponent.new(teams: @teams, red_zones_data: @red_zones_data) %>
              <%= render KeyPersonRisksDetailsComponent.new(teams: @teams, risks_data: @key_person_risks_data) %>
           </div>

           <div class="mb-8">
              <%= render UnitTechnologyTreemapComponent.new(teams: @teams, technologies_data: @technologies_data) %>
           </div>
        <% else %>
         <div class="alert alert--warning">
           <div class="flex">
             <div class="alert__icon-container">
               <svg class="h-6 w-6 alert__icon--warning" viewBox="0 0 20 20" fill="currentColor">
                 <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
               </svg>
             </div>
             <div class="alert__content">
                <p class="alert__text alert__text--warning">
                  <%= t('units.show.no_active_quarter.message') %>
                </p>
             </div>
           </div>
         </div>
       <% end %>
     </main>
   </main>
 </div>
