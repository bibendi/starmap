<div class="flex flex-col min-h-screen">
  <main class="flex-1 flex flex-col">
    <div class="page-header">
      <div class="page-header__container">
        <div class="page-header__content">
          <h1 class="page-title"><%= t('units.index.title') %></h1>
          <% if @units.any? %>
            <span class="badge badge--primary">
              <%= t('units.index.units_count', count: @units.total_count) %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <main class="page-main">
      <% if @units.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <% @units.each do |unit| %>
            <div class="card hover:shadow-lg transition-shadow duration-200">
              <div class="card__body">
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">
                      <%= link_to unit.name, unit_path(unit), class: "link" %>
                    </h3>
                  </div>
                  <span class="badge badge--neutral">
                    <%= unit.teams.active.count %> <%= t('units.index.unit_card.teams_count', count: unit.teams.active.count) %>
                  </span>
                </div>

                <div class="flex items-center gap-6 text-sm text-gray-600 dark:text-gray-400">
                  <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    <span>
                      <%= t('units.index.unit_card.unit_lead') %>: <%= unit.unit_lead&.display_name_or_full_name || '-' %>
                    </span>
                  </div>
                </div>

                <% if unit.teams.active.any? %>
                  <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
                    <p class="text-sm text-gray-500 dark:text-gray-400 mb-2"><%= t('units.index.unit_card.teams') %>:</p>
                    <div class="flex flex-wrap gap-2">
                      <% unit.teams.active.ordered.limit(5).each do |team| %>
                        <%= link_to team_path(name: team.name), class: "team-link" do %>
                          <span class="truncate max-w-[150px]"><%= team.name %></span>
                        <% end %>
                      <% end %>
                      <% if unit.teams.active.count > 5 %>
                        <span class="text-sm text-gray-500 dark:text-gray-400 self-center">
                          +<%= unit.teams.active.count - 5 %> <%= t('units.index.unit_card.more_teams') %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="flex justify-center">
          <%= paginate @units %>
        </div>
      <% else %>
        <div class="alert alert--warning">
          <div class="flex">
            <div class="alert__icon-container">
              <svg class="h-6 w-6 alert__icon--warning" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="alert__content">
              <h3 class="text-lg font-medium text-yellow-800 dark:text-yellow-300 mb-2">
                <%= t('units.index.empty.title') %>
              </h3>
              <p class="alert__text alert__text--warning">
                <%= t('units.index.empty.message') %>
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </main>
  </main>
</div>
