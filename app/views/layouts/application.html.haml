!!!
%html
  %head
    %title Starmap
    %meta{name: "viewport", content: "width=device-width,initial-scale=1"}
    %meta{name: "csrf-token", content: form_authenticity_token}
    = csrf_meta_tags
    = csp_meta_tag

    = stylesheet_link_tag "application", "data-turbo-track": "reload"
    = javascript_include_tag "application", "data-turbo-track": "reload", defer: true

  %body.bg-gray-50
    / Main navigation
    %nav.bg-white.shadow-sm.border-b.border-gray-200
      .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
        .flex.justify-between.h-16
          .flex
            .flex-shrink-0.flex.items-center
              = link_to "Starmap", root_path, class: "text-xl font-bold text-gray-900"
            .hidden.sm:ml-6.sm:flex.sm:space-x-8
              = link_to "Обзор", overview_dashboard_path, class: "border-transparent text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium"

              - if user_signed_in?
                = link_to "Мой дашборд", personal_dashboard_path, class: "border-transparent text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium"
                = link_to "Оценки", skill_ratings_path, class: "border-blue-500 text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium"

                - if current_user.team_lead?
                  = link_to "Команда", team_dashboard_path, class: "border-transparent text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium"

                - if current_user.admin?
                  = link_to "Админка", "#", class: "border-transparent text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium"

          .flex.items-center
            - if user_signed_in?
              .flex.items-center.space-x-4
                %span.text-sm.text-gray-700= current_user.display_name
                = link_to "Выйти", destroy_user_session_path, method: :delete, class: "bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-2 rounded-md text-sm font-medium"
            - else
              = link_to "Войти", new_user_session_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium"

    / Flash messages
    #flash
      = render partial: "shared/flash"

    / Main content
    %main.py-6
      = yield
