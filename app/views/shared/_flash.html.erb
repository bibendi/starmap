<% if notice %>
  <div class="flash-message flash-notice bg-green-100 border-l-4 border-green-500 p-4 text-green-800">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <i class="fas fa-check-circle mr-3 text-green-500"></i>
      </div>
      <div class="flex-1">
        <%= notice %>
      </div>
    </div>
  </div>
<% end %>

<% if alert %>
  <div class="flash-message flash-alert bg-red-100 border-l-4 border-red-500 p-4 text-red-800">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <i class="fas fa-exclamation-circle mr-3 text-red-500"></i>
      </div>
      <div class="flex-1">
        <%= alert %>
      </div>
    </div>
  </div>
<% end %>
