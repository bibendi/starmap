<div class="page--centered">
  <div class="container--narrow">
    <h2 class="heading--centered mt-6">Войти в Starmap</h2>
  </div>
  <div class="card card--centered">
    <div class="card--plain">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "form--vertical px-4 sm:px-10" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <div>
          <%= f.label :email, "Email", class: "form-label" %>
          <div class="form-field">
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
          </div>
        </div>
        <div>
          <%= f.label :password, "Пароль", class: "form-label" %>
          <div class="form-field">
            <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
          </div>
        </div>
        <% if devise_mapping.rememberable? %>
          <div class="form-actions">
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "form-checkbox" %>
              <%= f.label :remember_me, "Запомнить меня", class: "form-checkbox-label" %>
            </div>
            <div class="text-sm">
              <%= link_to "Забыли пароль?", new_password_path(resource_name), class: "link" %>
            </div>
          </div>
        <% end %>
        <div class="form-submit">
          <%= f.submit "Войти", class: "btn btn--primary w-full" %>
        </div>
      <% end %>
      <% if OIDC_ENABLED %>
        <div class="px-4 sm:px-10 mt-6">
          <div class="relative">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-gray-300 dark:border-gray-600"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-4 bg-white dark:bg-gray-800 text-gray-500">или</span>
            </div>
          </div>
        </div>
        <div class="px-4 sm:px-10 mt-6">
          <%= button_to user_oidc_omniauth_authorize_path, method: :post, class: "btn btn--secondary w-full justify-center gap-2", data: { turbo: false } do %>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
            Войти через OpenID
          <% end %>
        </div>
      <% end %>
      <div class="mt-6 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
