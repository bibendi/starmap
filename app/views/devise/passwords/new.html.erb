<div class="page--centered">
  <div class="container--narrow">
    <h2 class="heading--centered mt-6">Забыли пароль?</h2>
  </div>
  <div class="card card--centered">
    <div class="card--plain">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "form--vertical px-4 sm:px-10" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <div>
          <%= f.label :email, "Email", class: "form-label" %>
          <div class="form-field">
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
          </div>
        </div>
        <div class="form-submit">
          <%= f.submit "Отправить инструкции", class: "btn btn--primary w-full" %>
        </div>
      <% end %>
      <div class="mt-6 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
