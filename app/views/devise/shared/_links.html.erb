<div class="mt-6 text-center">
  <% if controller_name != 'sessions' %>
    <p class="text-body">
      Уже есть аккаунт?
      <%= link_to "Войти", new_session_path(resource_name), class: "link" %>
    </p>
  <% end %>
  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p class="text-body mt-2">
      Нет аккаунта?
      <%= link_to "Зарегистрироваться", new_registration_path(resource_name), class: "link" %>
    </p>
  <% end %>
  <% if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p class="text-body mt-2">
      Не получили письмо с подтверждением?
      <%= link_to "Отправить повторно", new_confirmation_path(resource_name), class: "link" %>
    </p>
  <% end %>
</div>
