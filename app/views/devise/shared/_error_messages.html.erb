<% if resource.errors.any? %>
  <div class="alert alert--danger mb-4" role="alert">
    <strong class="alert__heading">Ошибки:</strong>
    <ul class="alert__list">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
