<div class="flex flex-col min-h-screen">
   <main class="flex-1 flex flex-col">
     <div class="page-header">
       <div class="page-header__container">
         <div class="page-header__content">
           <h1 class="page-title"><%= t('teams.show.title') %></h1>
           <% if @current_quarter %>
             <span class="badge badge--primary">
               <%= @current_quarter.name %>
             </span>
           <% end %>
         </div>
       </div>
     </div>

     <main class="page-main">
       <% if @current_quarter %>
         <div class="card mb-8">
           <div class="card__body">
             <div class="flex items-center justify-between">
               <div class="flex items-center gap-8">
                 <div>
                   <dt class="label"><%= t('teams.show.team') %></dt>
                   <dd class="value--large"><%= @team&.name || t('teams.show.not_assigned') %></dd>
                 </div>
                 <div>
                   <dt class="label"><%= t('teams.show.team_lead') %></dt>
                   <dd class="value--medium"><%= @team&.team_lead&.display_name_or_full_name || '-' %></dd>
                 </div>
               </div>
               <div class="flex items-center gap-8">
                 <div>
                   <dt class="label"><%= t('teams.show.unit') %></dt>
                   <dd class="value--medium"><%= @team&.unit&.name || '-' %></dd>
                 </div>
                 <div>
                   <dt class="label"><%= t('teams.show.unit_lead') %></dt>
                   <dd class="value--medium"><%= @team&.unit&.unit_lead&.display_name_or_full_name || '-' %></dd>
                 </div>
               </div>
             </div>
             <div class="flex items-center gap-6 text-sm text-gray-600 dark:text-gray-400">
               <span class="flex items-center gap-2">
                 <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                 </svg>
                  <strong><%= @team_members.size %></strong> <%= t('teams.show.members', count: @team_members.size) %>
               </span>
               <span class="flex items-center gap-2">
                 <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
                 </svg>
                  <strong><%= @technology_counts.values.sum %></strong> <%= t('teams.show.technologies', count: @technology_counts.values.sum) %>
                   <span class="ml-2 badge badge--danger"><%= t('teams.show.criticality.high') %>: <%= @technology_counts[:high] %></span>
                   <span class="badge badge--warning"><%= t('teams.show.criticality.normal') %>: <%= @technology_counts[:normal] %></span>
               </span>
            </div>
          </div>
        </div>

         <div class="flex flex-wrap gap-6 mb-8">
           <%= render CoverageIndexComponent.new(teams: [@team]) %>
           <%= render MaturityIndexComponent.new(teams: [@team]) %>
            <%= render RedZonesCardComponent.new(red_zones_count: @red_zones_count) %>
           <%= render KeyPersonRisksComponent.new(teams: [@team]) %>
         </div>

          <% if @team_members.any? %>
            <% lead_member = @team_members.find { |m| m.id == @team.team_lead_id } %>
            <% other_members = @team_members.reject { |m| m.id == @team.team_lead_id } %>
            <div class="card mb-8">
              <div class="card__body">
                <!-- First row: Lead + first 3 members -->
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                  <% if lead_member %>
                    <% is_lead = true %>
                    <% member = lead_member %>
                    <% if policy(member).show? %>
                      <%= link_to user_path(member), class: "member-card member-card--lead" do %>
                        <div class="member-card__content">
                          <div class="member-card__name">
                            <%= member.full_name %>
                            <span class="badge badge--primary text-xs ml-1"><%= t('teams.show.team_lead_short') %></span>
                          </div>
                          <div class="member-card__position"><%= member.position || '-' %></div>
                        </div>
                      <% end %>
                    <% else %>
                      <div class="member-card member-card--disabled member-card--lead">
                        <div class="member-card__content">
                          <div class="member-card__name">
                            <%= member.full_name %>
                            <span class="badge badge--primary text-xs ml-1"><%= t('teams.show.team_lead_short') %></span>
                          </div>
                          <div class="member-card__position"><%= member.position || '-' %></div>
                        </div>
                      </div>
                    <% end %>
                  <% end %>
                  <% other_members[0..2].each do |member| %>
                    <% if policy(member).show? %>
                      <%= link_to user_path(member), class: "member-card" do %>
                        <div class="member-card__content">
                          <div class="member-card__name"><%= member.full_name %></div>
                          <div class="member-card__position"><%= member.position || '-' %></div>
                        </div>
                      <% end %>
                    <% else %>
                      <div class="member-card member-card--disabled">
                        <div class="member-card__content">
                          <div class="member-card__name"><%= member.full_name %></div>
                          <div class="member-card__position"><%= member.position || '-' %></div>
                        </div>
                      </div>
                    <% end %>
                  <% end %>
                </div>
                <!-- Second row: placeholder + remaining members -->
                <% if other_members.size > 3 %>
                  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 mt-3">
                    <div class="hidden lg:block" aria-hidden="true"></div>
                    <% other_members[3..-1].each do |member| %>
                      <% if policy(member).show? %>
                        <%= link_to user_path(member), class: "member-card" do %>
                          <div class="member-card__content">
                            <div class="member-card__name"><%= member.full_name %></div>
                            <div class="member-card__position"><%= member.position || '-' %></div>
                          </div>
                        <% end %>
                      <% else %>
                        <div class="member-card member-card--disabled">
                          <div class="member-card__content">
                            <div class="member-card__name"><%= member.full_name %></div>
                            <div class="member-card__position"><%= member.position || '-' %></div>
                          </div>
                        </div>
                      <% end %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

         <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
           <%= render RedZonesDetailsComponent.new(teams: [@team], red_zones_data: @red_zones_data) %>
           <%= render KeyPersonRisksDetailsComponent.new(teams: [@team]) %>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
          <%= render CompetencyDynamicsComponent.new(team: @team) %>
          <%= render UniversalityIndexComponent.new(team: @team) %>
        </div>

        <%= render TeamSkillMatrixComponent.new(team: @team, show_technology_links: policy(TeamTechnology.new(team: @team)).show?) %>

        <%= render TeamMemberMetricsComponent.new(team: @team) %>
      <% else %>
          <div class="alert alert--warning">
            <div class="flex">
              <div class="alert__icon-container">
                <svg class="h-6 w-6 alert__icon--warning" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="alert__content">
                <p class="alert__text alert__text--warning">
                   <%= t('teams.show.no_active_quarter.message') %>
                </p>
              </div>
            </div>
          </div>
      <% end %>
    </main>
  </main>
</div>
