<div class="flex flex-col min-h-screen">
  <main class="flex-1 flex flex-col">
    <div class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-6">
          <h1 class="text-3xl font-bold text-gray-900">Team Dashboard</h1>
          <% if @current_quarter %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-100 text-indigo-800">
              <%= @current_quarter.name %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <main class="flex-1 max-w-7xl mx-auto w-full py-6 sm:px-6 lg:px-8">
      <% if @current_quarter %>
        <div class="bg-white shadow sm:rounded-lg border border-gray-200 mb-8">
          <div class="px-6 py-6">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-8">
                <div>
                  <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Team</dt>
                  <dd class="text-2xl font-bold text-gray-900"><%= @team&.name || 'Not assigned' %></dd>
                </div>
                <div>
                  <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Team Lead</dt>
                  <dd class="text-lg font-medium text-gray-700"><%= @team&.team_lead&.display_name_or_full_name || '-' %></dd>
                </div>
              </div>
              <div class="flex items-center gap-8">
                <div>
                  <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Unit</dt>
                  <dd class="text-xl font-semibold text-gray-700"><%= @team&.unit&.name || '-' %></dd>
                </div>
                <div>
                  <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Unit Lead</dt>
                  <dd class="text-lg font-medium text-gray-700"><%= @team&.unit&.unit_lead&.display_name_or_full_name || '-' %></dd>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-6 text-sm text-gray-600">
              <span class="flex items-center gap-2">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                <strong><%= @team_members.size %></strong> участников
              </span>
              <span class="flex items-center gap-2">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
                </svg>
                <strong><%= @technology_counts.values.sum %></strong> технологий
                <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">High: <%= @technology_counts[:high] %></span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Normal: <%= @technology_counts[:normal] %></span>
              </span>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-6 mb-8">
          <%= render CoverageIndexComponent.new(team: @team) %>
          <%= render MaturityIndexComponent.new(team: @team) %>
          <%= render RedZonesCardComponent.new(team: @team) %>
          <%= render KeyPersonRisksComponent.new(team: @team) %>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <%= render RedZonesDetailsComponent.new(team: @team) %>
          <%= render KeyPersonRisksDetailsComponent.new(team: @team) %>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
          <%= render CompetencyDynamicsComponent.new(team: @team) %>
          <%= render UniversalityIndexComponent.new(team: @team) %>
        </div>

        <%= render TeamSkillMatrixComponent.new(team: @team) %>

        <!-- Team Member Metrics Table -->
        <div class="bg-white shadow sm:rounded-lg border border-gray-200 mt-6">
          <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Метрики участников команды</h3>
            <p class="mt-1 max-w-2xl text-sm text-gray-500">
              Показатель уровня компетенций, универсальности и концентрации экспертизы в разрезе критичности технологий.
            </p>
          </div>
          <div class="px-6 py-6 overflow-x-auto">
            <% if @team_member_metrics.any? && @team_members.any? %>
              <table class="min-w-full divide-y divide-gray-200">
                <thead>
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50">Метрика</th>
                    <% @team_members.each do |member| %>
                      <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider bg-gray-50 min-w-[100px]">
                        <div class="font-semibold text-gray-900"><%= member.full_name.split.first %></div>
                      </th>
                    <% end %>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 bg-white">

                  <!-- Competence Level Section -->
                  <tr class="bg-indigo-50">
                    <td colspan="<%= @team_members.size + 1 %>" class="px-4 py-3 text-sm font-bold text-indigo-900 border-b border-indigo-200">
                      <div class="flex items-center gap-2">
                        <span>Уровень компетенций</span>
                        <span class="inline-flex items-center text-xs text-gray-600 bg-indigo-100/50 px-2 py-0.5 rounded">
                          Сумма всех оценок по технологиям
                        </span>
                      </div>
                    </td>
                  </tr>
                  <tr>
                    <td class="px-4 py-2 text-sm font-medium text-gray-700">Всего</td>
                    <% @team_members.each do |member| %>
                      <% value = @team_member_metrics[member.id]&.dig(:competence_level, :total) || 0 %>
                      <% change = @team_member_metrics[member.id]&.dig(:competence_level, :total_change) %>
                      <td class="px-4 py-2 text-center">
                        <div class="relative inline-flex items-center justify-center">
                          <span class="inline-flex items-center justify-center px-3 py-1 rounded-full text-sm font-bold bg-gray-100 text-gray-800">
                            <%= value %>
                          </span>
                          <% if change && change != 0 %>
                            <span class="absolute -top-1 -right-6 text-[10px] font-medium flex items-center gap-0.5 <%= change > 0 ? 'text-green-600' : 'text-red-600' %>">
                              <% if change > 0 %>
                                <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                                  <path fill-rule="evenodd" d="M3.293 9.707a1 1 0 010-1.414l6-6a1 1 0 011.414 0l6 6a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L4.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                                </svg>
                              <% else %>
                                <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                                  <path fill-rule="evenodd" d="M16.707 10.293a1 1 0 010 1.414l-6 6a1 1 0 01-1.414 0l-6-6a1 1 0 111.414-1.414L9 14.586V3a1 1 0 012 0v11.586l4.293-4.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                </svg>
                              <% end %>
                              <%= change > 0 ? '+' : '' %><%= change %>
                            </span>
                          <% end %>
                        </div>
                      </td>
                    <% end %>
                  </tr>
                  <tr>
                    <td class="px-4 py-2 pl-8">
                      <span class="inline-flex items-center text-xs font-medium text-red-700 bg-red-50 px-2 py-0.5 rounded">
