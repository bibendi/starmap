<div class="flex flex-col min-h-screen">
  <main class="flex-1 flex flex-col">
    <div class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-6">
          <h1 class="text-3xl font-bold text-gray-900">Personal Dashboard</h1>
          <p class="text-sm text-gray-600">Добро пожаловать в Personal Dashboard!</p>
        </div>
      </div>
    </div>

    <main class="flex-1 max-w-7xl mx-auto w-full py-6 sm:px-6 lg:px-8">
      <% if @current_quarter %>
        <div class="bg-white shadow sm:rounded-lg border border-gray-200 mb-8">
          <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Информация о сотруднике</h3>
            <p class="mt-1 max-w-2xl text-sm text-gray-500">Данные текущего квартала</p>
          </div>
          <div class="px-6 py-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col">
                <dt class="text-sm font-medium text-gray-500">Текущий квартал</dt>
                <dd class="mt-1 text-2xl font-bold text-gray-900"><%= @current_quarter.year %>Q<%= @current_quarter.quarter_number %></dd>
              </div>
              <div class="flex flex-col">
                <dt class="text-sm font-medium text-gray-500">Оценок компетенций</dt>
                <dd class="mt-1 text-2xl font-bold text-gray-900"><%= @user_skill_ratings.size %></dd>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-6 mb-8">
          <div class="flex-1 min-w-[250px] bg-gradient-to-br from-indigo-50 to-blue-50 shadow rounded-xl p-6 border border-indigo-100 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between mb-4">
              <dt class="text-sm font-medium text-indigo-700 truncate">Critical Expertise Index</dt>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                <svg class="h-4 w-4 text-indigo-600 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
            <dd class="text-3xl font-bold text-gray-900"><%= "#{@critical_expertise_index}%" %></dd>
            <div class="text-xs text-gray-500 mt-1">Индекс критической экспертизы</div>
          </div>

          <div class="flex-1 min-w-[250px] bg-gradient-to-br from-green-50 to-emerald-50 shadow rounded-xl p-6 border border-green-100 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between mb-4">
              <dt class="text-sm font-medium text-green-700 truncate">Active Action Plans</dt>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <svg class="h-4 w-4 text-green-600 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
            <dd class="text-3xl font-bold text-gray-900"><%= @action_plans.size %></dd>
            <div class="text-xs text-gray-500 mt-1">Активных планов развития</div>
          </div>
        </div>

        <% if @user_skill_ratings.any? %>
          <div class="bg-white shadow sm:rounded-lg border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
              <h3 class="text-lg leading-6 font-medium text-gray-900">Ваши компетенции</h3>
              <p class="mt-1 max-w-2xl text-sm text-gray-500">Текущие оценки по технологиям</p>
            </div>
            <div class="px-6 py-6">
              <div class="space-y-3">
                <% @user_skill_ratings.each do |rating| %>
                  <div class="flex justify-between items-center p-4 bg-gray-50 rounded-lg border border-gray-200 hover:bg-white transition-colors duration-200 shadow-sm">
                    <div class="flex flex-col">
                      <span class="text-sm font-medium text-gray-900"><%= rating.technology.name %></span>
                      <span class="text-xs text-gray-500"><%= rating.technology.category %></span>
                    </div>
                    <div class="flex items-center">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium
                        <%= case rating.rating
                             when 3 then 'bg-green-100 text-green-800'
                             when 2 then 'bg-blue-100 text-blue-800'
                             when 1 then 'bg-yellow-100 text-yellow-800'
                             else 'bg-gray-100 text-gray-800'
                           end %>">
                        <%= "Уровень: #{rating.rating}/3" %>
                      </span>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <div class="bg-blue-50 border-l-4 border-blue-400 p-6 rounded-xl shadow">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm text-blue-700">
                  У вас еще нет оценок компетенций. Перейдите в раздел "Оценки" чтобы добавить оценки.
                </p>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-xl shadow">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm text-yellow-700">
                Нет активного квартала. Пожалуйста, создайте квартал в админке.
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </main>
  </main>
</div>
