<div class="flex flex-col min-h-screen">
  <main class="flex-1 flex flex-col">
    <div class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-6">
          <h1 class="text-3xl font-bold text-gray-900">Overview Dashboard</h1>
          <p class="text-sm text-gray-600">Добро пожаловать в Overview Dashboard!</p>
        </div>
      </div>
    </div>

    <main class="flex-1 max-w-7xl mx-auto w-full py-6 sm:px-6 lg:px-8">
      <% if @current_quarter %>
        <div class="flex flex-wrap gap-6 mb-8">
          <div class="flex-1 min-w-[250px] bg-gradient-to-br from-indigo-50 to-blue-50 shadow rounded-xl p-6 border border-indigo-100 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between mb-4">
              <dt class="text-sm font-medium text-indigo-700 truncate">Coverage Index</dt>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                <svg class="h-4 w-4 text-indigo-600 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
            <dd class="text-3xl font-bold text-gray-900"><%= "#{@coverage_index}%" %></dd>
            <div class="text-xs text-gray-500 mt-1">Показатель покрытия технологий</div>
          </div>

          <div class="flex-1 min-w-[250px] bg-gradient-to-br from-blue-50 to-cyan-50 shadow rounded-xl p-6 border border-blue-100 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between mb-4">
              <dt class="text-sm font-medium text-blue-700 truncate">Maturity Index</dt>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                <svg class="h-4 w-4 text-blue-600 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
            <dd class="text-3xl font-bold text-gray-900"><%= "#{@maturity_index}/3.0" %></dd>
            <div class="text-xs text-gray-500 mt-1">Уровень зрелости компетенций</div>
          </div>

          <div class="flex-1 min-w-[250px] bg-gradient-to-br from-red-50 to-orange-50 shadow rounded-xl p-6 border border-red-100 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between mb-4">
              <dt class="text-sm font-medium text-red-700 truncate">Red Zones</dt>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                <svg class="h-4 w-4 text-red-600 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
            <dd class="text-3xl font-bold text-gray-900"><%= @red_zones.size %></dd>
            <div class="text-xs text-gray-500 mt-1">Критические технологии</div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Red Zones Details -->
          <div class="bg-white shadow sm:rounded-lg border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
              <h3 class="text-lg leading-6 font-medium text-gray-900">Red Zones</h3>
              <p class="mt-1 max-w-2xl text-sm text-gray-500">Технологии с высокой критичностью и низким покрытием.</p>
            </div>
            <div class="px-6 py-6">
              <% if @red_zones.any? %>
                <div class="space-y-3">
                  <% @red_zones.each do |tech_id, count| %>
                    <% tech = Technology.find(tech_id) %>
                    <div class="flex justify-between items-center p-4 bg-gray-50 rounded-lg border border-gray-200 hover:bg-white transition-colors duration-200 shadow-sm">
                      <div class="flex flex-col">
                        <span class="text-sm font-medium text-gray-900"><%= tech.name %></span>
                        <span class="text-xs text-gray-500"><%= tech.category %></span>
                      </div>
                      <div class="flex items-center">
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                          <%= "Experts: #{count}" %>
                        </span>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="text-sm text-gray-500 text-center py-4">Красных зон не обнаружено.</p>
              <% end %>
            </div>
          </div>

          <!-- Teams Overview -->
          <div class="bg-white shadow sm:rounded-lg border border-gray-200">
            <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
              <h3 class="text-lg leading-6 font-medium text-gray-900">Teams</h3>
              <p class="mt-1 max-w-2xl text-sm text-gray-500">Обзор команд и их состава.</p>
            </div>
            <div class="px-6 py-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <% @teams.each do |team| %>
                  <div class="flex flex-col items-center p-4 border border-gray-200 rounded-lg hover:shadow-md transition-shadow cursor-pointer">
                    <div class="flex-shrink-0 h-16 w-16 bg-indigo-100 rounded-full flex items-center justify-center mb-3">
                      <span class="text-indigo-700 font-bold text-xl"><%= team.name[0] %></span>
                    </div>
                    <div class="text-center">
                      <h4 class="text-sm font-medium text-gray-900"><%= team.name %></h4>
                      <p class="text-xs text-gray-500"><%= "#{team.users.count} members" %></p>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% else %>
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-xl shadow">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm text-yellow-700">
                Нет активного квартала. Пожалуйста, создайте квартал в админке.
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </main>
  </main>
</div>
