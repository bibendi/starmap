= form_with model: skill_rating, local: true, data: { turbo_frame: "skill_rating_form" } do |form|
  - if skill_rating.errors.any?
    .bg-red-50.border.border-red-200.text-red-700.px-4.py-3.rounded.mb-4
      %h2= "#{pluralize(skill_rating.errors.count, 'ошибка')} препятствует сохранению:"
      %ul
        - skill_rating.errors.full_messages.each do |message|
          %li= message

  .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-4
    %div
      = form.label :user_id, "Пользователь", class: "block text-sm font-medium text-gray-700 mb-1"
      = form.collection_select :user_id, @users, :id, :full_name,
                              { include_blank: "Выберите пользователя" },
                              { class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" }

    %div
      = form.label :technology_id, "Технология", class: "block text-sm font-medium text-gray-700 mb-1"
      = form.collection_select :technology_id, @technologies, :id, :name,
                              { include_blank: "Выберите технологию" },
                              { class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" }

    %div
      = form.label :quarter_id, "Квартал", class: "block text-sm font-medium text-gray-700 mb-1"
      = form.collection_select :quarter_id, @quarters, :id, :full_name,
                              { include_blank: "Выберите квартал" },
                              { class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" }

    %div
      = form.label :rating, "Оценка", class: "block text-sm font-medium text-gray-700 mb-1"
      .rating-scale{
        data: {
          controller: "rating-scale",
          "rating-scale-current-rating-value": skill_rating.rating.to_s,
          "rating-scale-show-description-value": "true"
        }
      }
        .visual.flex.items-center.space-x-2.mb-3
          - (1..3).each do |level|
            %button{
              type: "button",
              class: "w-10 h-10 rounded-full border-2 border-gray-300 flex items-center justify-center text-sm font-bold hover:scale-110 transition-transform",
              data: {
                action: "rating-scale#selectRating rating-scale#previewRating mouseout->rating-scale#resetPreview",
                rating: level.to_s
              }
            }
              = level

        = form.hidden_field :rating,
                           value: skill_rating.rating,
                           data: { "rating-scale-target": "input" }

        - if skill_rating.rating > 0
          .description.hidden.mt-2.p-3.bg-blue-50.rounded-md
            %p.text-sm.text-blue-800{ data: { "rating-scale-target": "description" } }
              = {
                1 => "Имею представление - Могу выполнять простые задачи под присмотром или в паре с коллегой",
                2 => "Свободно владею - Могу самостоятельно взять задачу средней сложности и довести ее до production",
                3 => "Могу учить других - Могу объяснить архитектурные решения, провести код-ревью и быть ментором"
              }[skill_rating.rating]
        - else
          .description.hidden.mt-2.p-3.bg-gray-50.rounded-md
            %p.text-sm.text-gray-600{ data: { "rating-scale-target": "description" } }
              Выберите оценку от 0 до 3

        .rating-descriptions.mt-4.grid.grid-cols-1.md:grid-cols-2.gap-3.text-xs
          .descr-0.flex.items-start.space-x-2.p-2.rounded{ class: skill_rating.rating == 0 ? 'bg-blue-50 border border-blue-200' : 'bg-gray-50' }
            .font-medium.text-blue-600.w-8 0:
            %span.text-gray-700 "Не имею представления" - Слышал об этом, но на практике не сталкивался. Нужен онбординг с нуля
          .descr-1.flex.items-start.space-x-2.p-2.rounded{ class: skill_rating.rating == 1 ? 'bg-blue-50 border border-blue-200' : 'bg-gray-50' }
            .font-medium.text-blue-600.w-8 1:
            %span.text-gray-700 "Имею представление" - Могу выполнять простые задачи под присмотром или в паре с коллегой
          .descr-2.flex.items-start.space-x-2.p-2.rounded{ class: skill_rating.rating == 2 ? 'bg-blue-50 border border-blue-200' : 'bg-gray-50' }
            .font-medium.text-green-600.w-8 2:
            %span.text-gray-700 "Свободно владею" - Могу самостоятельно взять задачу средней сложности и довести ее до production
          .descr-3.flex.items-start.space-x-2.p-2.rounded{ class: skill_rating.rating == 3 ? 'bg-blue-50 border border-blue-200' : 'bg-gray-50' }
            .font-medium.text-purple-600.w-8 3:
            %span.text-gray-700 "Могу учить других" - Могу объяснить архитектурные решения, провести код-ревью и быть ментором

  .mb-4
    = form.label :comment, "Комментарий", class: "block text-sm font-medium text-gray-700 mb-1"
    = form.text_area :comment,
                    rows: 3,
                    placeholder: "Дополнительные комментарии к оценке...",
                    class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"

  .mb-4
    = form.label :reason, "Обоснование", class: "block text-sm font-medium text-gray-700 mb-1"
    = form.text_area :reason,
                    rows: 2,
                    placeholder: "Почему вы поставили именно эту оценку?",
                    class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"

  .flex.justify-end.space-x-3
    = link_to "Отмена", skill_ratings_path, class: "px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50"
    = form.submit "Сохранить", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
