- provide :title, "Новая оценка компетенций"

.page-header.flex.items-center.justify-between.mb-6
  %div
    %h1.text-2xl.font-bold.text-gray-900 Новая оценка компетенций
    - if @quarter
      %p.text-sm.text-gray-600.mt-1 Квартал: #{@quarter.year} Q#{@quarter.quarter_number}
      %span.inline-flex.items-center.px-2.5.py-0.5.rounded-full.text-xs.font-medium.mt-2{
        class: {
          'draft' => 'bg-gray-100 text-gray-800',
          'active' => 'bg-green-100 text-green-800',
          'closed' => 'bg-yellow-100 text-yellow-800',
          'archived' => 'bg-red-100 text-red-800'
        }[@quarter.status]
      }
        = {
          'draft' => 'Черновик',
          'active' => 'Активный',
          'closed' => 'Завершен',
          'archived' => 'Архивирован'
        }[@quarter.status]

  .actions
    = link_to skill_ratings_path(quarter_id: @quarter&.id),
              class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do
      %i.fas.fa-arrow-left.mr-2
      К списку оценок

- # Проверяем, можно ли редактировать оценки в этом квартале
- if @quarter && !@quarter.editable?
  .bg-yellow-50.border.border-yellow-200.rounded-md.p-4.mb-6
    .flex
      .flex-shrink-0
        %i.fas.fa-exclamation-triangle.text-yellow-400
      .ml-3
        %h3.text-sm.font-medium.text-yellow-800 Ограничение на редактирование
        %div.mt-2.text-sm.text-yellow-700
          %p Нельзя создавать или редактировать оценки в кварталах со статусом "#{@quarter.status}".
          - if @quarter.closed?
            %p.mt-1 Закрытый квартал можно только просматривать.
          - elsif @quarter.archived?
            %p.mt-1 Архивированные кварталы доступны только для просмотра.

- # Основная форма
.skill-rating-form
  - if @quarter && @quarter.editable? && policy(@skill_rating).create?
    = render partial: "form", locals: { skill_rating: @skill_rating, users: @users, technologies: @technologies }
  - else
    .bg-white.rounded-lg.shadow.p-8.text-center
      %p.text-gray-500.mb-4
        - if !@quarter
          Квартал не выбран
        - elsif !@quarter.editable?
          Нельзя редактировать оценки в этом квартале
        - else
          У вас нет прав для создания оценок

      = link_to skill_ratings_path,
                class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" do
        %i.fas.fa-arrow-left.mr-2
        Вернуться к списку

- # Справка по шкале оценок
.help-section.bg-blue-50.border.border-blue-200.rounded-md.p-4.mt-6
  .flex
    .flex-shrink-0
      %i.fas.fa-info-circle.text-blue-400
    .ml-3
      %h3.text-sm.font-medium.text-blue-800 Шкала оценок компетенций
      .mt-2.text-sm.text-blue-700
        %dl.space-y-2
          %div.flex.items-start
            %dt.font-medium.w-16 0:
            %dd "Не имею представления" - Слышал об этом, но на практике не сталкивался. Нужен онбординг с нуля
          %div.flex.items-start
            %dt.font-medium.w-16 1:
            %dd "Имею представление" - Могу выполнять простые задачи под присмотром или в паре с коллегой
          %div.flex.items-start
            %dt.font-medium.w-16 2:
            %dd "Свободно владею" - Могу самостоятельно взять задачу средней сложности и довести ее до production
          %div.flex.items-start
            %dt.font-medium.w-16 3:
            %dd "Могу учить других" - Могу объяснить архитектурные решения, провести код-ревью и быть ментором
