<% provide :title, "Управление оценками компетенций" %>

<div class="page-header flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Управление оценками компетенций</h1>
    <% if @quarter %>
      <p class="text-sm text-gray-600 mt-1">Квартал: <%= @quarter.year %> Q<%= @quarter.quarter_number %></p>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium mt-2 <%= {
        'draft' => 'bg-gray-100 text-gray-800',
        'active' => 'bg-green-100 text-green-800',
        'closed' => 'bg-yellow-100 text-yellow-800',
        'archived' => 'bg-red-100 text-red-800'
      }[@quarter.status] %>">
        <%= {
          'draft' => 'Черновик',
          'active' => 'Активный',
          'closed' => 'Завершен',
          'archived' => 'Архивирован'
        }[@quarter.status] %>
      </span>
    <% end %>
  </div>
  <% if @quarter && policy(SkillRating.new(quarter: @quarter)).create? %>
    <div class="actions">
      <%= link_to new_skill_rating_path(quarter_id: @quarter.id),
                  class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500",
                  data: { turbo_frame: "skill_rating_form" } do %>
        <i class="fas fa-plus-circle mr-2"></i>
        Добавить оценку
      <% end %>
    </div>
  <% end %>
</div>

<!-- Контейнер для Hotwire Turbo Frame -->
<turbo-frame id="skill_ratings_list" data-turbo-target="skill_ratings_list">
</turbo-frame>

<!-- Фильтры и поиск -->
<div class="bg-white rounded-lg shadow mb-6 p-4"
     data-controller="filters"
     data-filters-auto-submit-value="true"
     data-filters-debounce-ms-value="500">
  <%= form_with url: skill_ratings_path, method: :get, class: "grid grid-cols-1 md:grid-cols-6 gap-4", data: { "filters-target": "form" } do |form| %>
    <div class="md:col-span-2">
      <%= form.label :search, "Поиск", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :search, value: params[:search],
                          placeholder: "Поиск по пользователю или технологии...",
                          class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                          data: { "filters-target": "search" } %>
    </div>

    <div class="md:col-span-1">
      <%= form.label :quarter_id, "Квартал", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.collection_select :quarter_id, @quarters, :id, :full_name,
                                  { include_blank: "Все кварталы", selected: params[:quarter_id] },
                                  {
                                    class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                                    data: { "filters-target": "quarter" }
                                  } %>
    </div>

    <div class="md:col-span-1">
      <%= form.label :user_id, "Пользователь", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.collection_select :user_id, @users, :id, :full_name,
                                  { include_blank: "Все пользователи", selected: params[:user_id] },
                                  {
                                    class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                                    data: { "filters-target": "user" }
                                  } %>
    </div>

    <div class="md:col-span-1">
      <%= form.label :technology_id, "Технология", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.collection_select :technology_id, @technologies, :id, :name,
                                  { include_blank: "Все технологии", selected: params[:technology_id] },
                                  {
                                    class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                                    data: { "filters-target": "technology" }
                                  } %>
    </div>

    <div class="md:col-span-1">
      <%= form.label :status, "Статус", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.select :status,
                      options_for_select([
                        ["Все статусы", ""],
                        ["Черновик", "draft"],
                        ["На утверждении", "submitted"],
                        ["Утверждено", "approved"],
                        ["Отклонено", "rejected"]
                      ], params[:status]),
                      {
                        class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                        data: { "filters-target": "status" }
                      } %>
    </div>

    <div class="md:col-span-6 flex justify-between items-center">
      <div class="flex space-x-4">
        <% quarter_statuses = { 'draft' => 'Черновик', 'active' => 'Активный', 'closed' => 'Завершен', 'archived' => 'Архивирован' } %>
        <% quarter_status_colors = { 'draft' => 'bg-gray-100 text-gray-800', 'active' => 'bg-green-100 text-green-800', 'closed' => 'bg-yellow-100 text-yellow-800', 'archived' => 'bg-red-100 text-red-800' } %>
        <% quarter_statuses.each do |status, label| %>
          <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium <%= quarter_status_colors[status] %>">
            <%= label %>
          </span>
        <% end %>
      </div>
      <div class="flex space-x-3">
        <% if params[:search].present? || params[:quarter_id].present? || params[:user_id].present? || params[:technology_id].present? || params[:status].present? %>
          <%= link_to "Сбросить", skill_ratings_path,
                      class: "px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50",
                      data: { action: "filters#clearFilters" } %>
        <% end %>
        <%= form.submit "Фильтр",
                        class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700",
                        data: { "filters-target": "submit" } %>
      </div>
    </div>
  <% end %>
</div>

<!-- Статистика -->
<div class="stats-grid grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
  <!-- Общее количество -->
  <div class="bg-white rounded-lg shadow p-4">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <i class="fas fa-clipboard-list text-blue-500 text-2xl"></i>
      </div>
      <div class="ml-3">
        <p class="text-sm font-medium text-gray-500">Всего оценок</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @skill_ratings.total_count %></p>
      </div>
    </div>
  </div>

  <!-- На утверждении -->
  <div class="bg-white rounded-lg shadow p-4">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <i class="fas fa-clock text-yellow-500 text-2xl"></i>
      </div>
      <div class="ml-3">
        <p class="text-sm font-medium text-gray-500">На утверждении</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @skill_ratings_submitted_count %></p>
      </div>
    </div>
  </div>

  <!-- Утверждено -->
  <div class="bg-white rounded-lg shadow p-4">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <i class="fas fa-check-circle text-green-500 text-2xl"></i>
      </div>
      <div class="ml-3">
        <p class="text-sm font-medium text-gray-500">Утверждено</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @skill_ratings_approved_count %></p>
      </div>
    </div>
  </div>

  <!-- Средняя оценка -->
  <div class="bg-white rounded-lg shadow p-4">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <i class="fas fa-star text-purple-500 text-2xl"></i>
      </div>
      <div class="ml-3">
        <p class="text-sm font-medium text-gray-500">Средняя оценка</p>
        <p class="text-2xl font-semibold text-gray-900"><%= (@average_rating || 0).round(1) %></p>
      </div>
    </div>
  </div>
</div>

<!-- Turbo Frame для формы создания/редактирования -->
<turbo-frame id="skill_rating_form">
  <!-- Форма появится здесь при необходимости -->
</turbo-frame>

<!-- Список оценок -->
<div class="skill-ratings-list">
  <%= render partial: "list", locals: { skill_ratings: @skill_ratings } %>
</div>

<!-- Бэкап на случай если JavaScript отключен -->
<noscript>
  <div class="mt-6 p-4 bg-yellow-50 rounded-md">
    <p class="text-yellow-800">
      Для полной функциональности рекомендуется включить JavaScript.
      <%= link_to "Страница без JavaScript", skill_ratings_path(format: :html), class: "text-yellow-800 underline" %>
    </p>
  </div>
</noscript>
