<div class="flex flex-col min-h-screen">
  <main class="flex-1 flex flex-col">
    <div class="page-header">
      <div class="page-header__container">
        <div class="page-header__content">
          <div>
            <h1 class="page-title"><%= @user.full_name %></h1>
            <p class="text-gray-600 dark:text-gray-400 mt-1"><%= @user.email %></p>
          </div>
          <% unless @user.active? %>
            <span class="badge badge--secondary">
              <%= t('users.show.status.inactive') %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <main class="page-main">
      <div class="card mb-8">
        <div class="card__body">
          <div class="flex items-center justify-between">
             <div class="flex items-center gap-8">
               <div>
                 <dt class="label"><%= t('users.show.position') %></dt>
                 <dd class="value--medium"><%= @user.position || '-' %></dd>
               </div>
               <div>
                 <dt class="label"><%= t('users.show.role') %></dt>
                 <dd class="value--medium"><%= t("activerecord.attributes.user.roles.#{@user.role}") %></dd>
               </div>
             </div>
            <% if @user.team.present? %>
              <div class="flex items-center gap-8">
                <div>
                  <dt class="label"><%= t('users.show.team') %></dt>
                  <dd class="value--large">
                    <%= link_to @user.team.name,
                        team_path(@user.team),
                        class: "link" %>
                  </dd>
                </div>
                <% if @user.team.unit.present? %>
                  <div>
                    <dt class="label"><%= t('users.show.unit') %></dt>
                    <dd class="value--medium"><%= @user.team.unit.name %></dd>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <%# Skill ratings section %>
      <% if @current_quarter && @user.team.present? %>
        <div class="card">
          <div class="card__body">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">
                  <%= t('users.show.skill_ratings.title') %>
                </h3>
                <p class="text-gray-600 dark:text-gray-400 mt-1">
                  <%= @current_quarter.full_name %>
                  <% if @current_quarter.evaluation_period? %>
                    <span class="badge badge--warning ml-2">
                      <%= t('users.show.skill_ratings.evaluation_open') %>
                    </span>
                  <% end %>
                </p>
              </div>
              <%= link_to t('users.show.skill_ratings.view_button'),
                  user_skill_ratings_path(@user),
                  class: "btn btn--primary" %>
            </div>
          </div>
        </div>
      <% end %>

      <%= render PendingApprovalsComponent.new(users: @pending_users, current_user: current_user) %>
    </main>
  </main>
</div>