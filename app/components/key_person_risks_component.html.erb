<div class="metric-card metric-card--danger">
   <div class="content-row content-row--between spacing-sm">
     <dt class="metric-card__label metric-card__label--danger"><%= label %></dt>
     <span class="badge badge--danger">
       <svg class="badge__icon badge__icon--danger" viewBox="0 0 20 20" fill="currentColor">
         <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
       </svg>
     </span>
  </div>
   <dd class="metric-card__value"><%= @key_person_risks_count %></dd>
   <div class="metric-card__description"><%= description %></div>
</div>
