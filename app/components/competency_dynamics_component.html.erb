<div class="card">
  <div class="card__header">
     <h3 class="card__title"><%= t('components.competency_dynamics.title') %></h3>
     <p class="card__description"><%= t('components.competency_dynamics.description') %></p>
  </div>
  <div class="card__body">
    <% if @competency_dynamics.any? %>
      <div class="space-y-3">
        <% @competency_dynamics.each do |user_id, change| %>
          <% user = @team_members.find { |u| u.id == user_id } %>
            <div class="card-item">
              <div class="content-card">
                <span class="text-heading"><%= user&.full_name %></span>
             </div>
              <div class="content-row">
               <span class="badge <%= change >= 0 ? 'badge--success' : 'badge--danger' %>">
                 <%= change >= 0 ? '+' : '' %><%= change %>
               </span>
             </div>
           </div>
        <% end %>
      </div>
    <% else %>
        <p class="text-muted--center py-4"><%= t('components.competency_dynamics.no_data') %></p>
    <% end %>
  </div>
</div>
