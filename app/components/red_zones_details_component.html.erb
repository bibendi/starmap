<div class="card" data-controller="vertical-pagination" data-vertical-pagination-items-per-page-value="5">
  <div class="card__header relative">
     <div class="pr-20">
       <h3 class="card__title"><%= t('components.red_zones_details.title') %></h3>
       <p class="card__description"><%= t('components.red_zones_details.description', count: red_zones_technologies_count) %></p>
     </div>
     
      <% if any_red_zones? && carousel_slides.size > 5 %>
       <div class="absolute right-4 bottom-4 flex items-center space-x-2">
          <button data-vertical-pagination-target="prevButton"
                  data-action="click->vertical-pagination#prev"
                  class="icon-btn icon-btn--nav">
            <svg class="icon-btn__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button data-vertical-pagination-target="nextButton"
                  data-action="click->vertical-pagination#next"
                  class="icon-btn icon-btn--nav">
            <svg class="icon-btn__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
       </div>
     <% end %>
  </div>
  <div class="card__body">
    <% if any_red_zones? %>
          <div data-vertical-pagination-target="container" class="space-y-4">
            <% carousel_slides.each_with_index do |slide, index| %>
              <div data-vertical-pagination-target="item" class="card-item">
                <div class="content-card">
                  <span class="text-heading"><%= slide[:technology]&.name %></span>
                  <span class="text-subtle"><%= slide[:technology]&.category %></span>
                </div>
                <% if multiple_teams? %>
                    <div class="mt-2">
                      <div class="flex flex-wrap gap-x-1 gap-y-1 text-sm text-gray-600 dark:text-gray-400">
                        <% slide[:red_zones].each_with_index do |red_zone, index| %>
                          <span class="group relative inline-block">
                            <%= link_to red_zone[:team]&.name, team_path(name: red_zone[:team]&.name), class: "link hover:underline truncate max-w-[140px]" %><% if index < slide[:red_zones].size - 1 %>,<% end %>
                             <div class="tooltip tooltip--bottom !whitespace-normal max-w-[280px] opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto">
                               <div class="flex items-start gap-2 py-1">
                                 <span class="badge badge--danger badge--sm flex-shrink-0">
                                   <%= "#{red_zone[:expert_count]}/#{red_zone[:target_experts]}" %>
                                 </span>
                                 <% if red_zone[:experts].any? %>
                                   <div class="text-sm text-gray-800 dark:text-gray-200 leading-snug">
                                     <%= red_zone[:experts].map { |e| "<span class='whitespace-nowrap'>#{e.full_name}</span>" }.join(", ").html_safe %>
                                   </div>
                                 <% end %>
                               </div>
                               <span class="tooltip__arrow"></span>
                             </div>
                          </span>
                        <% end %>
                      </div>
                    </div>
                <% else %>
                  <% red_zone = slide[:red_zones].first %>
                  <div class="content-row mt-2 group relative inline-block">
                    <span class="badge badge--danger cursor-help">
                      <%= "#{red_zone[:expert_count]}/#{red_zone[:target_experts]}" %>
                    </span>
                    <% if red_zone[:experts].any? %>
                      <div class="tooltip tooltip--bottom !whitespace-normal max-w-[280px] opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto">
                        <div class="flex items-start gap-2 py-1">
                          <span class="badge badge--danger badge--sm flex-shrink-0">
                            <%= "#{red_zone[:expert_count]}/#{red_zone[:target_experts]}" %>
                          </span>
                          <div class="text-sm text-gray-800 dark:text-gray-200 leading-snug">
                            <%= red_zone[:experts].map { |e| "<span class='whitespace-nowrap'>#{e.full_name}</span>" }.join(", ").html_safe %>
                          </div>
                        </div>
                        <span class="tooltip__arrow"></span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
    <% else %>
      <p class="text-muted--center py-4"><%= t('components.red_zones_details.no_data') %></p>
    <% end %>
  </div>
</div>
