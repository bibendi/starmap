<div class="metric-card metric-card--primary">
   <div class="content-row content-row--between spacing-sm">
     <dt class="metric-card__label metric-card__label--primary"><%= label %></dt>
      <span class="badge badge--primary">
        <svg class="badge__icon badge__icon--primary" viewBox="0 0 20 20" fill="currentColor">
         <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
       </svg>
     </span>
  </div>
   <dd class="metric-card__value"><%= "#{@coverage_index}%" %></dd>
   <div class="metric-card__description"><%= description %></div>
</div>
