<div class="card mt-6">
  <div class="card__header">
     <h3 class="card__title"><%= t('components.team_skill_matrix.title') %></h3>
     <p class="card__description"><%= t('components.team_skill_matrix.description') %></p>
  </div>
   <div class="card__body overflow-x-auto">
    <% if any_data? %>
       <table class="table">
        <thead>
          <tr>
               <th class="table__header-cell"><%= t('components.team_skill_matrix.technology') %></th>
               <th class="table__header-cell table__header-cell--center"><%= t('components.team_skill_matrix.bus_factor') %></th>
            <% team_members.each do |member| %>
                <th class="table__header-cell table__header-cell--center"><%= member.full_name.split.first %></th>
            <% end %>
          </tr>
        </thead>
         <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% team_skill_matrix.each do |tech_id, user_ratings| %>
            <% tech = technology_for(tech_id) %>
            <% bus_factor_data = bus_factor_for(tech_id) %>
            <tr>
               <td class="table__cell table__cell--heading">
                 <div class="content-card">
                    <span class="text-heading"><%= tech&.name %></span>
                   <div class="content-row content-row--gap mt-0.5">
                      <span class="text-subtle"><%= tech&.category %></span>
                    <% criticality = bus_factor_data&.dig(:criticality) || tech&.criticality %>
                    <% if criticality == 'high' %>
                       <span class="criticality-badge criticality-badge--high">
                         <svg class="criticality-badge__icon criticality-badge__icon--high" viewBox="0 0 20 20" fill="currentColor">
                           <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                         </svg>
                          <%= t('components.team_skill_matrix.criticality.high') %>
                       </span>
                    <% elsif criticality == 'normal' %>
                       <span class="criticality-badge criticality-badge--normal">
                         <svg class="criticality-badge__icon criticality-badge__icon--normal" viewBox="0 0 20 20" fill="currentColor">
                           <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                         </svg>
                          <%= t('components.team_skill_matrix.criticality.normal') %>
                       </span>
                    <% elsif criticality == 'low' %>
                       <span class="criticality-badge criticality-badge--low">
                         <svg class="criticality-badge__icon criticality-badge__icon--low" viewBox="0 0 20 20" fill="currentColor">
                           <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                         </svg>
                          <%= t('components.team_skill_matrix.criticality.low') %>
                       </span>
                    <% end %>
                  </div>
                </div>
              </td>
               <td class="table__cell table__cell--center">
                 <% if bus_factor_data %>
                   <div class="relative-container">
                     <span class="badge <%= case bus_factor_data[:risk_level] when 'high' then 'badge--danger' when 'medium' then 'badge--warning' else 'badge--success' end %>">
                       <% if bus_factor_data[:risk_level] == 'high' %>
                         <svg class="w-3 h-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
                           <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                         </svg>
                       <% elsif bus_factor_data[:risk_level] == 'medium' %>
                         <svg class="w-3 h-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
                           <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                         </svg>
                       <% else %>
                         <svg class="w-3 h-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
                           <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                         </svg>
                       <% end %>
                       <%= bus_factor_data[:count] %>/<%= bus_factor_data[:target] %>
                     </span>
                    <% if bus_factor_data.key?(:change) && bus_factor_data[:change] != 0 %>
                       <span class="change-indicator <%= bus_factor_data[:change] > 0 ? 'change-indicator--positive' : 'change-indicator--negative' %>">
                        <% if bus_factor_data[:change] > 0 %>
                          <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M3.293 9.707a1 1 0 010-1.414l6-6a1 1 0 011.414 0l6 6a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L4.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                          </svg>
                        <% else %>
                          <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M16.707 10.293a1 1 0 010 1.414l-6 6a1 1 0 01-1.414 0l-6-6a1 1 0 111.414-1.414L9 14.586V3a1 1 0 012 0v11.586l4.293-4.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                          </svg>
                        <% end %>
                        <%= bus_factor_data[:change] > 0 ? '+' : '' %><%= bus_factor_data[:change] %>
                      </span>
                    <% end %>
                  </div>
                <% else %>
                   <span class="text-muted">-</span>
                <% end %>
              </td>
              <% team_members.each do |member| %>
                <% rating = rating_for(tech_id, member.id) %>
                <% change = change_for(tech_id, member.id) %>
                <td class="table__cell table__cell--center">
                   <div class="relative-container">
                     <span class="rating-indicator <%= case rating when 3 then 'rating-indicator--expert' when 2 then 'rating-indicator--proficient' when 1 then 'rating-indicator--basic' else 'rating-indicator--none' end %>">
                       <%= rating > 0 ? rating : '-' %>
                     </span>
                    <% if change && change != 0 %>
                        <span class="change-indicator <%= change > 0 ? 'change-indicator--positive' : 'change-indicator--negative' %>">
                        <% if change > 0 %>
                          <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M3.293 9.707a1 1 0 010-1.414l6-6a1 1 0 011.414 0l6 6a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L4.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                          </svg>
                        <% else %>
                          <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M16.707 10.293a1 1 0 010 1.414l-6 6a1 1 0 01-1.414 0l-6-6a1 1 0 111.414-1.414L9 14.586V3a1 1 0 012 0v11.586l4.293-4.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                          </svg>
                        <% end %>
                        <%= change > 0 ? '+' : '' %><%= change %>
                      </span>
                    <% end %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
       <div class="legend">
          <div class="legend-item"><span class="legend-badge legend-badge--expert">3</span> <%= t('components.team_skill_matrix.legend.expert') %></div>
          <div class="legend-item"><span class="legend-badge legend-badge--proficient">2</span> <%= t('components.team_skill_matrix.legend.proficient') %></div>
          <div class="legend-item"><span class="legend-badge legend-badge--basic">1</span> <%= t('components.team_skill_matrix.legend.basic') %></div>
          <div class="legend-item"><span class="legend-badge legend-badge--none">0</span> <%= t('components.team_skill_matrix.legend.none') %></div>
       </div>
    <% else %>
        <p class="text-muted--center py-4"><%= t('components.team_skill_matrix.no_data') %></p>
    <% end %>
  </div>
</div>
