<div class="bg-white shadow sm:rounded-lg border border-gray-200 mt-6">
  <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
    <h3 class="text-lg leading-6 font-medium text-gray-900">Карта навыков команды</h3>
    <p class="mt-1 max-w-2xl text-sm text-gray-500">Показатель покрытия технологий и уровень зрелости компетенций.</p>
  </div>
  <div class="px-6 py-6 overflow-x-auto">
    <% if any_data? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Технология</th>
            <th class="px-3 py-2 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Bus Factor</th>
            <% team_members.each do |member| %>
              <th class="px-3 py-2 text-center text-xs font-medium text-gray-500 uppercase tracking-wider"><%= member.full_name.split.first %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% team_skill_matrix.each do |tech_id, user_ratings| %>
            <% tech = technology_for(tech_id) %>
            <% bus_factor_data = bus_factor_for(tech_id) %>
            <tr>
              <td class="px-3 py-2 whitespace-nowrap text-sm font-medium text-gray-900">
                <div class="flex flex-col">
                  <span class="text-gray-900"><%= tech&.name %></span>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-xs text-gray-500"><%= tech&.category %></span>
                    <% criticality = bus_factor_data&.dig(:criticality) || tech&.criticality %>
                    <% if criticality == 'high' %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">
                        <svg class="w-3 h-3 mr-1 text-red-500" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                        High
                      </span>
                    <% elsif criticality == 'normal' %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">
                        <svg class="w-3 h-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                        </svg>
                        Norm
                      </span>
                    <% elsif criticality == 'low' %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">
                        <svg class="w-3 h-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                        </svg>
                        Low
                      </span>
                    <% end %>
                  </div>
                </div>
              </td>
              <td class="px-3 py-2 whitespace-nowrap text-center">
                <% if bus_factor_data %>
                  <div class="relative inline-flex items-center justify-center">
                    <span class="inline-flex items-center justify-center px-2 py-1 rounded-full text-xs font-medium <%=
                      case bus_factor_data[:risk_level]
                      when 'high' then 'bg-red-100 text-red-800'
                      when 'medium' then 'bg-orange-100 text-orange-800'
                      else 'bg-green-100 text-green-800'
                      end
                    %>">
                      <% if bus_factor_data[:risk_level] == 'high' %>
                        <svg class="w-3 h-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                      <% elsif bus_factor_data[:risk_level] == 'medium' %>
                        <svg class="w-3 h-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                      <% else %>
                        <svg class="w-3 h-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                      <%= bus_factor_data[:count] %>/<%= bus_factor_data[:target] %>
                    </span>
                    <% if bus_factor_data.key?(:change) && bus_factor_data[:change] != 0 %>
                      <span class="absolute -top-1 -right-6 text-[10px] font-medium flex items-center gap-0.5 <%=
                        bus_factor_data[:change] > 0 ? 'text-green-600' : 'text-red-600'
                      %>">
                        <% if bus_factor_data[:change] > 0 %>
                          <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M3.293 9.707a1 1 0 010-1.414l6-6a1 1 0 011.414 0l6 6a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L4.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                          </svg>
                        <% else %>
                          <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M16.707 10.293a1 1 0 010 1.414l-6 6a1 1 0 01-1.414 0l-6-6a1 1 0 111.414-1.414L9 14.586V3a1 1 0 012 0v11.586l4.293-4.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                          </svg>
                        <% end %>
                        <%= bus_factor_data[:change] > 0 ? '+' : '' %><%= bus_factor_data[:change] %>
                      </span>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-gray-400">-</span>
                <% end %>
              </td>
              <% team_members.each do |member| %>
                <% rating = rating_for(tech_id, member.id) %>
                <% change = change_for(tech_id, member.id) %>
                <td class="px-3 py-2 whitespace-nowrap text-center">
                  <div class="relative inline-flex items-center justify-center">
                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold <%=
                      case rating
                      when 3 then 'bg-green-100 text-green-800'
                      when 2 then 'bg-blue-100 text-blue-800'
                      when 1 then 'bg-yellow-100 text-yellow-800'
                      else 'bg-gray-100 text-gray-400'
                      end
                    %>">
                      <%= rating > 0 ? rating : '-' %>
                    </span>
                    <% if change && change != 0 %>
                      <span class="absolute -top-1 -right-6 text-[10px] font-medium flex items-center gap-0.5 <%= change > 0 ? 'text-green-600' : 'text-red-600' %>">
                        <% if change > 0 %>
                          <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M3.293 9.707a1 1 0 010-1.414l6-6a1 1 0 011.414 0l6 6a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L4.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                          </svg>
                        <% else %>
                          <svg class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M16.707 10.293a1 1 0 010 1.414l-6 6a1 1 0 01-1.414 0l-6-6a1 1 0 111.414-1.414L9 14.586V3a1 1 0 012 0v11.586l4.293-4.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                          </svg>
                        <% end %>
                        <%= change > 0 ? '+' : '' %><%= change %>
                      </span>
                    <% end %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
      <div class="mt-4 flex gap-4 text-xs text-gray-500">
        <div class="flex items-center"><span class="w-4 h-4 rounded-full bg-green-100 text-green-800 inline-flex items-center justify-center mr-1">3</span> Может учить других</div>
        <div class="flex items-center"><span class="w-4 h-4 rounded-full bg-blue-100 text-blue-800 inline-flex items-center justify-center mr-1">2</span> Свободно владеет</div>
        <div class="flex items-center"><span class="w-4 h-4 rounded-full bg-yellow-100 text-yellow-800 inline-flex items-center justify-center mr-1">1</span> Имеет представление</div>
        <div class="flex items-center"><span class="w-4 h-4 rounded-full bg-gray-100 text-gray-400 inline-flex items-center justify-center mr-1">0</span> Не владеет</div>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 text-center py-4">Нет данных о навыках команды.</p>
    <% end %>
  </div>
</div>
