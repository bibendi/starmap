{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/skills/rails/SKILL.md",
    ".opencode/skills/hotwire/SKILL.md",
  ],
  "mcp": {
    "starmap": {
      "enabled": true,
      "type": "remote",
